stage('test-examples') {

    if (env.SGX == "1") {
        env.MODE = "sgx"
    }
    else {
        env.MODE = "direct"
    }

    if (env.no_cpu.toInteger() > 16) {
            try {
		timeout(time:30,unit: 'MINUTES') {
                  sh '''
			cd CI-Examples/mysql
			make privileges
			make ${MAKEOPTS} all && make ${MAKEOPTS} check
			sleep 150s
                        make conncheck
			make clean
                    '''
		}
         } catch (Exception e) { }
     }
}
